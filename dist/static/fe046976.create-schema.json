          {
            "rules": [
              {
                "flag": "custom"
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "slug",
        "type": "slug"
      },
      {
        "rows": 4,
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              },
              {
                "flag": "max",
                "constraint": 200
              }
            ],
            "level": "error"
          }
        ],
        "name": "excerpt",
        "type": "text"
      },
      {
        "options": {
          "collapsible": true,
          "collapsed": true
        },
        "description": "Optional key takeaways rendered at the top of the article. Improves AI search discoverability.",
        "fields": [
          {
            "validation": [
              {
                "rules": [
                  {
                    "flag": "max",
                    "constraint": 5
                  }
                ],
                "level": "error"
              }
            ],
            "description": "3–5 bullet points. Lead each with the core fact.",
            "of": [
              {
                "type": "string"
              }
            ],
            "name": "keyTakeaways",
            "type": "array"
          }
        ],
        "name": "aiSummaryBlock",
        "type": "object",
        "title": "AI Summary Block"
      },
      {
        "options": {
          "collapsible": true,
          "collapsed": false
        },
        "fields": [
          {
            "validation": [
              {
                "rules": [
                  {
                    "flag": "max",
                    "constraint": 70
                  }
                ],
                "level": "error"
              }
            ],
            "description": "Optional override for the browser title and social title. Defaults to the post title.",
            "name": "title",
            "type": "string",
            "title": "SEO Title"
          },
          {
            "rows": 3,
            "validation": [
              {
                "rules": [
                  {
                    "flag": "max",
                    "constraint": 160
                  }
                ],
                "level": "error"
              }
            ],
            "description": "Optional override for search and social descriptions. Defaults to the excerpt.",
            "name": "description",
            "type": "text",
            "title": "Meta Description"
          },
          {
            "validation": [
              {
                "rules": [
                  {
                    "flag": "uri",
                    "constraint": {
                      "options": {
                        "scheme": [
                          "/^http$/",
                          "/^https$/"
                        ],
                        "allowRelative": false,
                        "relativeOnly": false,
                        "allowCredentials": false
                      }
                    }
                  }
                ],
                "level": "error"
              }
            ],
            "description": "Optional canonical URL override. Leave blank to use the live post URL.",
            "name": "canonicalUrl",
            "type": "url",
            "title": "Canonical URL"
          },
          {
            "initialValue": false,
            "description": "Prevent search engines from indexing this post.",
            "name": "noIndex",
            "type": "boolean",
            "title": "No index"
          },
          {
            "rows": 4,
            "validation": [
              {
                "rules": [
                  {
                    "flag": "max",
                    "constraint": 420
                  }
                ],
                "level": "error"
              }
            ],
            "description": "Optional plain-language summary for AI retrieval, internal reuse, and future metadata use.",
            "name": "aiSummary",
            "type": "text",
            "title": "AI Summary"
          }
        ],
        "name": "seo",
        "type": "object",
        "title": "SEO"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "Optional. Leave blank for text-led editorial posts that do not need a hero image.",
