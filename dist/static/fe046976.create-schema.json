  {
    "fields": [
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "description": "Internal name for this banner campaign",
        "name": "campaignName",
        "type": "string"
      },
      {
        "options": {
          "list": [
            {
              "title": "Top Banner (Main Page)",
              "value": "top"
            },
            {
              "title": "Right Sidebar",
              "value": "sidebar"
            }
          ]
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  "top",
                  "sidebar"
                ]
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "placement",
        "type": "string",
        "title": "Banner Placement"
      },
      {
        "options": {
          "hotspot": true
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "description": "Banner image for desktop (728x90 for top, 300x250 for sidebar)",
        "name": "desktopImage",
        "type": "image"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "Banner image for mobile (320x50 for top banner, same as desktop for sidebar)",
        "name": "mobileImage",
        "type": "image"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "description": "Alternative text for accessibility",
        "name": "altText",
        "type": "string"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "uri",
                "constraint": {
                  "options": {
                    "scheme": [
                      "/^http$/",
                      "/^https$/"
                    ],
                    "allowRelative": false,
                    "relativeOnly": false,
                    "allowCredentials": false
                  }
                }
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "description": "URL to redirect when banner is clicked",
        "name": "clickThroughUrl",
        "type": "url",
        "title": "Click Through URL"
      },
      {
        "initialValue": true,
        "description": "Should the link open in a new tab?",
        "name": "targetBlank",
        "type": "boolean",
        "title": "Open in New Tab"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "description": "When this banner should start showing",
        "name": "startDate",
        "type": "datetime"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "description": "When this banner should stop showing",
        "name": "endDate",
        "type": "datetime"
      },
      {
        "initialValue": true,
        "description": "Is this banner currently active?",
        "name": "isActive",
        "type": "boolean",
        "title": "Active"
      },
      {
        "initialValue": 5,
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              },
              {
                "flag": "min",
                "constraint": 1
              },
              {
                "flag": "max",
                "constraint": 10
              }
            ],
            "level": "error"
          }
        ],
        "description": "Higher numbers show first if multiple banners are active (1-10)",
        "name": "priority",
        "type": "number"
      },
      {
        "initialValue": true,
        "description": "Track clicks on this banner",
        "name": "clickTracking",
        "type": "boolean",
        "title": "Enable Click Tracking"
      },
      {
        "description": "Internal notes about this banner campaign",
        "name": "notes",
        "type": "text",
        "title": "Internal Notes"
      }
    ],
    "name": "banner",
    "type": "document",
    "title": "Advertisement Banner"
